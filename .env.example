# --- Analisi AI (opzionale) -------------------------------------------------
# Chiave API OpenRouter (https://openrouter.ai/keys).
# Se assente, l'app funziona comunque in modalità "solo analisi statica".
OPENROUTER_API_KEY=

# Modello di default usato per l'analisi AI (sovrascrivibile dalla UI).
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# --- Acquisizione repository (opzionale) ------------------------------------
# Token GitHub (solo lettura) per alzare i rate limit delle API GitHub e
# accedere a repository privati. Non necessario per repo pubblici.
GITHUB_TOKEN=

# Token GitLab (solo lettura), stesso scopo per repository GitLab.
GITLAB_TOKEN=
